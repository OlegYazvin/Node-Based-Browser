{
  "name": "nodely-browser-gecko",
  "version": "0.1.0",
  "description": "The Nodely browser, built on Gecko for node-first research workflows.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "gecko:bootstrap": "node gecko/scripts/bootstrap-gecko.mjs",
    "gecko:apply-patches": "node gecko/scripts/apply-patches.mjs",
    "gecko:sync": "node gecko/scripts/sync-overlay.mjs",
    "gecko:doctor": "node gecko/scripts/doctor-gecko.mjs",
    "gecko:mozconfig": "node gecko/scripts/write-mozconfig.mjs",
    "gecko:refresh-branding": "node gecko/scripts/refresh-artifact-branding.mjs",
    "gecko:smoke": "node gecko/scripts/run-nodely-smoke.mjs",
    "gecko:stage-release": "node gecko/scripts/stage-release-artifacts.mjs",
    "installers": "node scripts/build-installers.mjs",
    "installers:prune": "node scripts/prune-installers.mjs",
    "installers:sync": "node scripts/sync-installers.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "24.7.2",
    "typescript": "5.9.3",
    "vite": "7.1.12",
    "vitest": "4.1.2"
