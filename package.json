{
  "name": "research-graph-browser",
  "productName": "Nodely Browser",
  "version": "0.1.0",
  "description": "A Blink-based browser built for node-first research workflows.",
  "private": true,
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
